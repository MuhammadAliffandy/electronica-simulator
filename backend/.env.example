# ============================================
# AI Electronics Simulator - Environment Config
# ============================================
# Copy this file to .env and configure:
#   cp .env.example .env

# Server Configuration
PORT=3001

# ============================================
# AI Provider Chain: OpenAI → Ollama → Mock
# The server tries each provider in order.
# If all fail, it uses the built-in mock tutor.
# ============================================

# OpenAI Configuration (optional)
# Leave empty to skip OpenAI and try Ollama instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama Configuration (optional)
# Install Ollama: https://ollama.com/download
# Then run: ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
